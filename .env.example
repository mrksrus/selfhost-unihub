# UniHub Docker Compose settings
#
# Copy this file to .env next to docker-compose.yml and fill in the required
# values before starting the stack.

# Frontend build-time setting. The published Docker image is built for the
# in-container Nginx reverse proxy, so /api is normally correct.
VITE_API_URL=/api

# Required Docker Compose secrets
# Generate random secrets with: openssl rand -base64 48
UNIHUB_MYSQL_PASSWORD=
UNIHUB_MYSQL_ROOT_PASSWORD=
UNIHUB_JWT_SECRET=
UNIHUB_ENCRYPTION_KEY=
UNIHUB_BOOTSTRAP_ADMIN_EMAIL=
UNIHUB_BOOTSTRAP_ADMIN_PASSWORD=

# Runtime settings currently live in docker-compose.yml under
# services.unihub.environment. Review these there for your deployment:
#
# ALLOWED_ORIGINS       Comma-separated frontend origins allowed by CORS.
# TRUST_PROXY_HEADERS   Set true only behind a trusted reverse proxy.
# TRUSTED_MAIL_HOSTS    Optional comma-separated allowlist for private/local
#                       mail or CalDAV hostnames.
