# Frontend build-time settings (Docker Compose now holds all secrets)
VITE_API_URL=/api

# Docker Compose required secrets
# Generate secrets with: openssl rand -base64 48
UNIHUB_MYSQL_PASSWORD=
UNIHUB_MYSQL_ROOT_PASSWORD=
UNIHUB_JWT_SECRET=
UNIHUB_ENCRYPTION_KEY=
UNIHUB_BOOTSTRAP_ADMIN_EMAIL=
UNIHUB_BOOTSTRAP_ADMIN_PASSWORD=
